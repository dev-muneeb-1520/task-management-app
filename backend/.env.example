# Backend environment template
# 1) Copy this file to .env
# 2) Update values for your machine
# 3) Run Prisma migrations and start the backend

# Required: PostgreSQL connection string
# Example format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/task_management_app?schema=public"

# Required: API server port
PORT=3001

# Required: JWT signing secret (use a long random value in production)
JWT_SECRET="replace-with-a-strong-secret"

# Optional: Token expiration values (defaults are shown)
# Examples: 15m, 1h, 7d, 30d
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Optional: Allowed frontend origins for CORS (comma-separated)
# Example: CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
CORS_ORIGIN="http://localhost:3000"